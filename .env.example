# aria-10k Environment Variables Example
# Copy this file to .env and configure your keys

# Mode Flags
USE_LOCAL_LLM=true         # true = Ollama, false = OpenAI/Anthropic
USE_LOCAL_VECTORDB=true    # true = ChromaDB, false = Pinecone

# LLM Configurations
LOCAL_LLM_MODEL=llama3     # Ollama model (e.g., llama3, mistral)
# Cloud LLM API Keys (Required if USE_LOCAL_LLM=false)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# SEC EDGAR Downloader Settings
# SEC strictly requires a User-Agent in the format: Name YourEmail@domain.com
SEC_API_USER_AGENT="YourName YourEmail@domain.com"

# Vector Database Configurations (Required if USE_LOCAL_VECTORDB=false)
PINECONE_API_KEY=
PINECONE_INDEX=aria-10k

# LangSmith Observability & Evaluations
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=aria-10k
LANGSMITH_API_KEY=
